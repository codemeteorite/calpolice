# MongoDB connection string
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/calpolice
# Local: mongodb://localhost:27017/calpolice
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/calpolice

# JWT secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_here

# Python AI service URL
# Local:      http://127.0.0.1:5001
# Production: https://your-railway-ai-service.up.railway.app
PYTHON_AI_URL=http://127.0.0.1:5001
AI_SERVICE_URL=http://127.0.0.1:5001

# Server port
PORT=5000

# Set to "production" on Railway
NODE_ENV=development

# Deployed client URL for CORS (your Netlify URL)
# Leave empty in local dev — localhost is always allowed
CLIENT_URL=https://your-app.netlify.app
